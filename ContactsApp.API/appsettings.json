{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ContactsAppDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  // JWT:Secret doit etre defini via dotnet user-secrets (dev) ou la variable d'env JWT__Secret (prod)
  // dotnet user-secrets set "JWT:Secret" "<votre-secret-32-caracteres-minimum>"
  "JWT": {
    "Secret": "__REPLACE_WITH_USER_SECRETS_OR_ENV__",
    "Issuer": "ContactsAppApi",
    "Audience": "ContactsAppApiUsers",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  }
}
